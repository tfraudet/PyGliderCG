# ===========================
# PyGliderCG Configuration
# ===========================

# ===== Database Configuration =====
# Path to DuckDB database file
DB_NAME=./data/gliders.db

# ===== Backend Server Configuration =====
# Backend API host binding (0.0.0.0 for all interfaces)
HOST=0.0.0.0

# Backend API port
PORT=8000

# Backend service URL (used by backend and API clients)
BACKEND_URL=http://localhost:8000

# React frontend API URL (optional in local dev: Vite proxy handles /api)
VITE_BACKEND_URL=

# ===== Application Settings =====
# Enable debug mode (false in production!)
APP_DEBUG_MODE=false

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ===== Security Configuration =====
# Secret key for JWT token signing and cookie encryption
# IMPORTANT: Change this to a strong random string in production!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your-secret-key-change-in-production

# ===== Python Configuration =====
# Prevent Python from buffering stdout
PYTHONUNBUFFERED=1

# Prevent Python from writing .pyc files
PYTHONDONTWRITEBYTECODE=1

# ===== Test Credentials (for e2e tests only) =====
# NOTE: These are for testing purposes only - never commit real credentials!
TEST_ADMIN_USERNAME=test_admin
TEST_ADMIN_PASSWORD=test_password_123

TEST_EDITOR_USERNAME=test_editor
TEST_EDITOR_PASSWORD=test_password_456

# ===== Production Settings (uncomment as needed) =====
# These should be set differently in production environments

# CORS allowed origins (comma-separated for production)
# CORS_ORIGINS=https://yourdomain.com,https://api.yourdomain.com

# JWT configuration for authentication
# JWT_EXPIRY_HOURS=24
# JWT_REFRESH_EXPIRY_DAYS=7

# Database connection pool size (for production)
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20
