{
	"CodeGPT.apiKey": "Groq",
	"sqltools.useNodeRuntime": true,
	"sqltools.connections": [
		{
			"previewLimit": 50,
			"driver": "DuckDB",
			"database": "${workspaceFolder:PyGliderCG}/data/gliders.db",
			"name": "gliders"
		}
	],
	"python.analysis.typeCheckingMode": "basic",
	"python.analysis.diagnosticSeverityOverrides": {
		
	},
	"python.testing.pytestArgs": [
		"tests"
	],
	"python.testing.unittestEnabled": false,
	"python.testing.pytestEnabled": true,
	"chat.tools.terminal.autoApprove": {
		"/^node -p \"JSON\\.stringify\\(require\\('\\./node_modules/@playwright/test/package\\.json'\\), null, 2\\)\" \\| sed -n '1,120p' && echo '---' && node -p \"JSON\\.stringify\\(require\\('\\./node_modules/playwright/package\\.json'\\), null, 2\\)\" \\| sed -n '1,120p'$/": {
			"approve": true,
			"matchCommandLine": true
		},
		"npm install": true,
		"npx tsc": true
	}
}